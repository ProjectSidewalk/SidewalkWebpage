dashboard.settings.username.error.length = Der Benutzername muss 3–30 Zeichen lang sein.
dashboard.settings.username.error.charset = Verwenden Sie nur Buchstaben, Zahlen, Binde- und Unterstriche.
dashboard.settings.username.error.allowed = Dieser Benutzername ist nicht erlaubt — bitte wählen Sie einen anderen.
dashboard.settings.username.error.taken = Dieser Benutzername ist bereits vergeben.
dashboard.settings.email = E-Mail
dashboard.settings.email.help = Wird für die Anmeldung und das Zurücksetzen des Passworts verwendet. Um Ihre E-Mail-Adresse zu ändern, wenden Sie sich an <a href="mailto:sidewalk@cs.uw.edu">sidewalk@cs.uw.edu</a>.
dashboard.settings.units = Maßeinheiten
dashboard.settings.units.metric = Kilometer & Meter
dashboard.settings.units.imperial = Meilen & Fuß
dashboard.settings.units.help = Die Einheiten folgen der Seitensprache, die Sie über das Sprachmenü in der oberen Leiste ändern können.
dashboard.settings.team = Team
dashboard.settings.team.label = Ihr Team
dashboard.settings.team.none = Kein Team
dashboard.settings.team.help = Treten Sie einem Team oder einer Klasse bei, um gemeinsam zu kartieren und in der Team-Bestenliste zu erscheinen. Wählen Sie "Kein Team", um Ihr aktuelles Team zu verlassen.
dashboard.settings.privacy = Privatsphäre
dashboard.settings.privacy.default.note = Diese Installation hält Profile standardmäßig privat. Aktivieren Sie diese Optionen, wenn Sie Ihren Namen und Fortschritt mit der Gemeinschaft teilen möchten.
dashboard.settings.leaderboard.toggle = Mich in der Bestenliste anzeigen
dashboard.settings.leaderboard.help = Wenn deaktiviert, erscheint Ihr Name in keiner Rangliste.
dashboard.settings.public.toggle = Mein Dashboard öffentlich machen
dashboard.settings.public.help = Wenn aktiviert, kann jeder in der Bestenliste auf Ihren Namen klicken und eine öffentliche Version Ihres Dashboards sehen (Ihre Statistiken, Abzeichen und Trophäen — nie Ihre E-Mail-Adresse). Wenn deaktiviert, wird Ihr Profil als "privat" angezeigt.
dashboard.settings.save = Änderungen speichern
dashboard.profile.tag = Öffentliches Profil
dashboard.profile.headline = {0} hat <strong>{1} Beschriftungen</strong> gesetzt und macht Gehwege damit barrierefreier.
dashboard.profile.map.caption = Wo diese Person unterwegs war — die erkundeten Straßen und Beschriftungen von {0}. Öffnen Sie die Legende zum Filtern.
dashboard.profile.notfound.title = Person nicht gefunden
dashboard.profile.notfound = Wir konnten niemanden mit dem Namen "{0}" finden.
dashboard.profile.notfound.detail = Der Name hat sich möglicherweise geändert. Gehen Sie zurück zur <a href="{0}">Bestenliste</a>, um die Person zu finden.
dashboard.profile.private = {0} hält das eigene Profil privat.
dashboard.profile.private.detail = Diese Person macht weiterhin Gehwege barrierefreier — sie hat sich nur entschieden, kein öffentliches Profil zu teilen.
dashboard.profile.trophy.none = 🏆 {0} hat noch keine Trophäen verdient — aber jede Beschriftung zählt.
leaderboard.intro = Jede Beschriftung macht Gehwege barrierefreier und sicherer für alle. So steht die Gemeinschaft da.
leaderboard.intro.you = Jede Beschriftung macht Gehwege barrierefreier und sicherer für alle. So stehen die Gemeinschaft — und Sie — da.
leaderboard.cta.title = Möchten Sie sehen, wo Sie stehen?
leaderboard.cta.detail = Erstellen Sie ein kostenloses Konto, um Ihre Beschriftungen zu verfolgen, Abzeichen und Trophäen zu verdienen und in der Liste aufzusteigen.
leaderboard.cta.signup = Konto erstellen
leaderboard.podium.title = Ganz oben auf dem Board
leaderboard.podium.intro = Die Allzeit-Spitze von {0}. 🏆
leaderboard.podium.labels = {0} Beschriftungen
leaderboard.podium.none = 🌱 Das Board fängt gerade erst an — seien Sie unter den Ersten an der Spitze. Legen Sie los!
leaderboard.alltime.title = {0} — Allzeit
leaderboard.alltime.intro = Die fleißigsten Kartierenden aller Zeiten in {0}, geordnet nach Gesamtpunktzahl.
leaderboard.alltime.none = 🌱 Noch keine Beschriftungen — Sie könnten der allererste Name hier sein.
leaderboard.explainer.summary = Wie wird die Rangliste berechnet?
leaderboard.explainer.body = Der Rang ist eine Gesamt-<strong>Punktzahl</strong>, die eine Balance aus <strong>gesetzten Beschriftungen</strong>, <strong>erkundeter Distanz</strong> und <strong>Beschriftungsgenauigkeit</strong> belohnt — stetiges, hochwertiges Kartieren zählt also mehr als bloße Menge. Deshalb sind die Beschriftungszahlen unten nicht streng geordnet. (Wochen- und Teamboard verwenden dieselbe Punktzahl.)
leaderboard.header.mapper = Kartierende/r
leaderboard.accuracy.explain = So wird die Genauigkeit berechnet:
leaderboard.accuracy.detail = Der Anteil der validierten Beschriftungen einer Person, den andere als korrekt bestätigt haben. Wird angezeigt, sobald mindestens 10 Beschriftungen validiert wurden.
leaderboard.thisweek.title = {0} diese Woche
leaderboard.thisweek.intro = Jeden Montag neu — der beste Ort, um schnell aufzusteigen.
leaderboard.thisweek.none = ✨ Diese Woche noch keine Beschriftungen — seien Sie die erste Person auf dem Board!
leaderboard.teams.title = Teams
leaderboard.teams.intro = Erstellen Sie ein Team oder treten Sie einem bei, um gemeinsam etwas zu bewirken!
leaderboard.teams.none = 👥 Noch keine Teams — seien Sie das erste! Gründen Sie eines und laden Sie Freunde oder Klassenkameraden ein.
leaderboard.you.title = Ihr Platz in der Gemeinschaft
leaderboard.you.intro = Wo Sie diese Woche stehen und wer direkt vor und hinter Ihnen liegt.
