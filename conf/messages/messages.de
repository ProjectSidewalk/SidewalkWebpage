dashboard.team.dialog.name.placeholder = z. B. Frau Riveras 7. Klasse
dashboard.team.dialog.desc = Beschreibung
dashboard.team.dialog.optional = (optional)
dashboard.team.dialog.desc.placeholder = Worum geht es in Ihrem Team?
dashboard.team.dialog.note = Jeder kann ein Team erstellen, aber nur Administratoren können eines löschen. Schreiben Sie an <a href="mailto:sidewalk@cs.uw.edu">sidewalk@cs.uw.edu</a>, wenn ein Team entfernt werden soll.
dashboard.team.dialog.submit = Erstellen & beitreten
